# Azure OpenAI / Azure AI Foundry
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
# AZURE_OPENAI_API_VERSION=        # Optional — omit to use SDK default ("preview")
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5

# Apify (Instagram scraping)
APIFY_API_TOKEN=<your-apify-token>

# Target Instagram accounts (comma-separated)
IG_TARGET_ACCOUNTS=hellocatie45

# How many days back to fetch posts (default: 7)
IG_LOOKBACK_DAYS=7

# Max posts to fetch per account (default: 20)
IG_RESULTS_LIMIT=20

# Max comments to fetch per post (default: 50)
IG_COMMENTS_LIMIT=50

# Schedule interval (hours)
WATCH_INTERVAL_HOURS=24

# Mailtrap.io (email report delivery)
# Get your token: Mailtrap dashboard → Sending → API Tokens
MAILTRAP_API_TOKEN=<your-mailtrap-api-token>
MAILTRAP_SENDER_EMAIL=noreply@your-verified-domain
MAILTRAP_SENDER_NAME=BeautyPulse Analytics

# Report recipients — comma-separated, used by scheduler/CLI and pre-filled in the UI
# The UI allows overriding this list before each run
REPORT_RECIPIENT_EMAILS=<your-email@example.com>, <another@example.com>
